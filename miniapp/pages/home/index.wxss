.hero {
  background: linear-gradient(150deg, rgba(255, 102, 153, 0.88) 0%, rgba(146, 118, 255, 0.9) 100%);
}

.subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.86);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.quick-item {
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  padding: 18rpx;
  border-radius: 18rpx;
  text-align: center;
  font-weight: 600;
  color: #fff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.step {
  display: flex;
  align-items: center;
  margin: 14rpx 0;
  color: rgba(250, 248, 255, 0.9);
}

.step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff7fac, #8c79ff);
  color: #fff;
  text-align: center;
  line-height: 44rpx;
  margin-right: 14rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 16rpx rgba(140, 121, 255, 0.35);
}

.feature {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 16rpx;
  padding: 18rpx;
  margin: 12rpx 0;
}
