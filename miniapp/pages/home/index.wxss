 .hero {
  background: linear-gradient(135deg, #ff4d6d, #ff7a8f);
  color: #fff;
}
.title { font-size: 40rpx; font-weight: 700; }
.subtitle { margin-top: 12rpx; opacity: 0.9; }
.quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-top: 24rpx; }
.quick-item { background: rgba(255,255,255,.2); padding: 18rpx; border-radius: 16rpx; text-align: center; }
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 16rpx; }
.step { display: flex; align-items: center; margin: 12rpx 0; color: #444; }
.step-index { width: 40rpx; height: 40rpx; border-radius: 50%; background: #ffe4ea; color: #ff4d6d; text-align: center; line-height: 40rpx; margin-right: 14rpx; font-weight: 700; }
.feature { background: #fff5f7; border: 1rpx solid #ffd3db; border-radius: 14rpx; padding: 18rpx; margin: 12rpx 0; color: #a42643; }
