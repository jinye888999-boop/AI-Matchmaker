.header {
  background: linear-gradient(135deg, rgba(255, 99, 151, 0.88), rgba(127, 111, 255, 0.9));
}

.tip {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.86);
}

.match {
  margin-top: 0;
}

.top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-weight: 600;
  color: #fff;
}

.score {
  color: #ffd6ec;
}

.reason {
  color: rgba(250, 247, 255, 0.88);
  margin: 8rpx 0;
}
