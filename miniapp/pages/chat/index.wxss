.chat-wrap {
  padding: 24rpx 18rpx;
  min-height: 72vh;
}

.msg {
  margin: 12rpx 0;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  max-width: 74%;
  box-shadow: 0 10rpx 24rpx rgba(10, 11, 26, 0.22);
}

.me {
  margin-left: auto;
  background: linear-gradient(135deg, #ff6a9f, #8c78ff);
  color: #fff;
}

.ta {
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  color: #fff;
}

.input-bar {
  display: flex;
  gap: 12rpx;
  padding: 18rpx;
  position: sticky;
  bottom: 0;
  background: rgba(23, 24, 42, 0.92);
  border-top: 1rpx solid rgba(255, 255, 255, 0.14);
}

.input-bar .primary-btn {
  margin-top: 0;
  width: 150rpx;
  height: 78rpx;
  line-height: 78rpx;
}

.input-bar input {
  flex: 1;
  margin: 0;
}
