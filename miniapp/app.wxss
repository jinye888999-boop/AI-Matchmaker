page {
  background:
    radial-gradient(circle at 10% -20%, rgba(255, 118, 165, 0.3) 0%, rgba(255, 118, 165, 0) 45%),
    radial-gradient(circle at 90% 10%, rgba(139, 120, 255, 0.28) 0%, rgba(139, 120, 255, 0) 42%),
    linear-gradient(180deg, #161628 0%, #1f1f35 38%, #24253d 100%);
  color: #f6f4ff;
  font-size: 28rpx;
}

.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(18rpx);
  border-radius: 28rpx;
  padding: 26rpx;
  margin: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(4, 6, 20, 0.35);
}

.card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 70%);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #ffffff;
}

.sub {
  margin-top: 10rpx;
  color: rgba(248, 245, 255, 0.75);
}

.content,
.row {
  color: rgba(247, 244, 255, 0.92);
  line-height: 1.8;
}

.label {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  color: #ffd0f1;
  font-weight: 600;
}

.primary-btn {
  margin-top: 22rpx;
  height: 86rpx;
  line-height: 86rpx;
  background: linear-gradient(135deg, #ff5f9d 0%, #ff7a7a 45%, #8b78ff 100%);
  color: #fff;
  border-radius: 999rpx;
  border: none;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 14rpx 34rpx rgba(255, 93, 157, 0.35);
}

.primary-btn::after {
  border: none;
}

input {
  display: block;
  margin: 14rpx 0;
  padding: 20rpx 22rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 18rpx;
  color: #fff;
}

input::placeholder {
  color: rgba(255, 255, 255, 0.55);
}

.center {
  text-align: center;
}

.emoji {
  font-size: 88rpx;
  margin-bottom: 12rpx;
}
