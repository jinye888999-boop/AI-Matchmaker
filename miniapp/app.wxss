page {
  background: #f6f7fb;
  color: #222;
  font-size: 28rpx;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}

.primary-btn {
  background: linear-gradient(120deg, #ff4d6d, #ff7a8f);
  color: white;
  border-radius: 999rpx;
}
